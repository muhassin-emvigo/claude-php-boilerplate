{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Bash(composer *)",
      "Bash(php *)",
      "Bash(vendor/bin/phpcs *)",
      "Bash(vendor/bin/phpstan *)",
      "Bash(vendor/bin/phpunit *)",
      "Bash(vendor/bin/phpmd *)",
      "Bash(vendor/bin/php-cs-fixer *)",
      "Bash(make *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git force *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-validate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "php -l $CLAUDE_FILE_PATH 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
