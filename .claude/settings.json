{
  "autoCompactEnabled": true,
  "autoCompactWindow": 300000,
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(php vendor/bin/phpcs*)",
      "Bash(vendor/bin/phpcs*)",
      "Bash(php -l*)",
      "Bash(php vendor/bin/phpstan*)",
      "Bash(php8.4 vendor/bin/phpunit*)",
      "Bash(xmllint --noout*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-validate.sh"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash cavemen/scripts/md-procedure.sh pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | python3 -c \"import sys,json; print(json.load(sys.stdin).get('tool_input',{}).get('file_path',''))\"); [ -n \"$FILE\" ] && php -l \"$FILE\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash cavemen/scripts/md-procedure.sh post"
          }
        ]
      }
    ]
  }
}
