<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         beStrictAboutTestsThatDoNotTestAnything="true"
         failOnRisky="true"
         failOnWarning="true">
    <testsuites>
        <testsuite name="Unit Tests">
            <directory suffix="Test.php">app/code/vendor/CustomShipping/Test/Unit</directory>
            <directory suffix="Test.php">app/code/vendor/Rgd/Inventory/Test/Unit</directory>
        </testsuite>
        <testsuite name="Integration Tests">
            <directory suffix="Test.php">app/code/vendor/CustomShipping/Test/Integration</directory>
            <directory suffix="Test.php">app/code/vendor/Rgd/Inventory/Test/Integration</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">app/code/vendor/CustomShipping</directory>
            <directory suffix=".php">app/code/vendor/Rgd/Inventory</directory>
        </include>
        <exclude>
            <directory>app/code/vendor/CustomShipping/Test</directory>
            <directory>app/code/vendor/Rgd/Inventory/Test</directory>
        </exclude>
    </source>
</phpunit>
