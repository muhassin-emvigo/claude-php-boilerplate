# ============================================================
# Docker Environment Variables
# Copy to .env in the docker/ directory: cp .env.docker.example .env
# ============================================================

# Nginx (8080 avoids conflict with XAMPP on port 80)
NGINX_PORT=8080

# Magento Marketplace keys (required for install-magento.sh)
MAGENTO_PUBLIC_KEY=
MAGENTO_PRIVATE_KEY=

# MySQL
DB_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=magento
MYSQL_USER=magento
MYSQL_PASSWORD=magento

# Redis
REDIS_PORT=6379

# OpenSearch
OPENSEARCH_PORT=9200

# Mailhog
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
