# ============================================================
# Magento 2 Module Boilerplate — Environment Variables
# Copy to .env: cp .env.example .env
# ============================================================

# Application
APP_ENV=local
APP_DEBUG=true

# Magento
MAGENTO_ADMIN_URL=admin
MAGENTO_DEPLOY_MODE=developer
# MAGENTO_ENCRYPTION_KEY=

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=magento
DB_USERNAME=magento
DB_PASSWORD=magento

# Redis (Cache)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_CACHE_DB=0
REDIS_SESSION_DB=2
REDIS_FPC_DB=1

# OpenSearch / Elasticsearch
SEARCH_ENGINE=opensearch
OPENSEARCH_HOST=127.0.0.1
OPENSEARCH_PORT=9200

# Mail (Development)
MAIL_HOST=127.0.0.1
MAIL_PORT=1025

# External Services (add your own)
# PAYMENT_API_KEY=
# SHIPPING_API_KEY=
# THIRD_PARTY_API_URL=

# Claude Code (optional)
# CLAUDE_API_KEY=
