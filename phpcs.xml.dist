<?xml version="1.0"?>
<ruleset name="Magento 2 Module">
    <description>PHPCS ruleset for Magento 2 module development</description>

    <!-- Arguments -->
    <arg name="basepath" value="."/>
    <arg name="cache" value=".phpcs-cache"/>
    <arg name="colors"/>
    <arg name="extensions" value="php,phtml"/>
    <arg value="ps"/> <!-- Show progress and sniff name -->

    <!-- Use Magento2 coding standard -->
    <rule ref="Magento2"/>

    <!-- Paths to check -->
    <file>app/code</file>

    <!-- Exclude patterns -->
    <exclude-pattern>*/Test/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/.claude/*</exclude-pattern>
    <!-- CLI/build scripts and root bootstrap files are not app/code and
         intentionally use echo/exit/direct file I/O; the Magento2 app
         coding standard doesn't apply to them. -->
    <exclude-pattern>*/scripts/*</exclude-pattern>
    <exclude-pattern>*/index\.php</exclude-pattern>
</ruleset>
