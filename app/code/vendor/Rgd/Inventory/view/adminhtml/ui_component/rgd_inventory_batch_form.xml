<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">rgd_inventory_batch_form.rgd_inventory_batch_form_data_source</item>
            <item name="component" xsi:type="string">Magento_Ui/js/form/form</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Batch Information</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="back">
                <url path="rgd_inventory/batch/index"/>
                <class>back</class>
                <label translate="true">Back</label>
            </button>
            <button name="delete">
                <url path="rgd_inventory/batch/delete"/>
                <class>delete</class>
                <label translate="true">Delete</label>
            </button>
            <button name="save">
                <url path="rgd_inventory/batch/save"/>
                <class>save primary</class>
                <label translate="true">Save Batch</label>
            </button>
        </buttons>
        <namespace>rgd_inventory_batch_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>rgd_inventory_batch_form.rgd_inventory_batch_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="rgd_inventory_batch_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="rgd_inventory/batch/save"/>
        </settings>
        <dataProvider class="Rgd\Inventory\Ui\DataProvider\BatchDataProvider" name="rgd_inventory_batch_form_data_source">
            <settings>
                <requestFieldName>batch_id</requestFieldName>
                <primaryFieldName>batch_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general" sortOrder="10">
        <settings>
            <label translate="true">General Information</label>
            <collapsible>false</collapsible>
        </settings>
        <field name="batch_id" formElement="hidden">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>batch_id</dataScope>
            </settings>
        </field>
        <field name="sku" sortOrder="10" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">SKU</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="batch_number" sortOrder="20" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Batch Number</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="max_text_length" xsi:type="number">64</rule>
                </validation>
            </settings>
        </field>
        <field name="source_code" sortOrder="30" formElement="select">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Source</label>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">default</item>
                                <item name="label" xsi:type="string">Default</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="expiry_date" sortOrder="40" formElement="date">
            <settings>
                <dataType>date</dataType>
                <label translate="true">Expiry Date</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <date>
                    <settings>
                        <options>
                            <!-- Without an explicit ISO dateFormat, Magento_Ui/js/form/element/date.js
                                 defaults outputDateFormat to 'MM/dd/y' (ICU), which BatchRepository's
                                 and Batch/Save's server-side Y-m-d format checks then always reject. -->
                            <option name="dateFormat" xsi:type="string">y-MM-dd</option>
                        </options>
                    </settings>
                </date>
            </formElements>
        </field>
        <field name="received_qty" sortOrder="50" formElement="input">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Received Qty</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-number" xsi:type="boolean">true</rule>
                    <rule name="validate-greater-than-zero" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="remaining_qty" sortOrder="60" formElement="input">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Remaining Qty</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-number" xsi:type="boolean">true</rule>
                    <rule name="validate-zero-or-greater" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="is_active" sortOrder="70" formElement="checkbox">
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Active</label>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="string">0</map>
                            <map name="true" xsi:type="string">1</map>
                        </valueMap>
                        <prefer>checkbox</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
    </fieldset>
</form>
