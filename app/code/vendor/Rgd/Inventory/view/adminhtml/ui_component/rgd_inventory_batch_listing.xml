<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">rgd_inventory_batch_listing.rgd_inventory_batch_listing_data_source</item>
            <item name="deps" xsi:type="string">rgd_inventory_batch_listing.rgd_inventory_batch_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>rgd_inventory_batch_listing_columns</spinner>
        <buttons>
            <button name="add">
                <url path="rgd_inventory/batch/edit"/>
                <class>primary</class>
                <label translate="true">Add New Batch</label>
            </button>
        </buttons>
    </settings>
    <dataSource name="rgd_inventory_batch_listing_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Rgd\Inventory\Ui\DataProvider\BatchListingDataProvider</argument>
            <argument name="name" xsi:type="string">rgd_inventory_batch_listing_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">batch_id</argument>
            <argument name="requestFieldName" xsi:type="string">batch_id</argument>
            <argument name="collectionFactory" xsi:type="object">Rgd\Inventory\Model\ResourceModel\Batch\CollectionFactory</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/provider</item>
                    <item name="update_url" xsi:type="url" path="mui/index/render"/>
                    <item name="storageConfig" xsi:type="array">
                        <item name="indexField" xsi:type="string">batch_id</item>
                    </item>
                    <!--
                        Magento\Ui\Controller\Adminhtml\Index\Render::validateAclResource()
                        (the mui/index/render async grid-data endpoint) reads this exact key —
                        $component->getContext()->getDataProvider()->getConfigData()['aclResource']
                        i.e. AbstractDataProvider::getConfigData() = $this->data['config'] ?? [].
                        This module's dataSource uses the raw <argument name="dataProvider"
                        xsi:type="configurableObject"> style (not the typed <dataProvider class="...">
                        + sibling <aclResource> element used elsewhere in core), so a sibling
                        <aclResource> element under <dataSource> is never wired into the
                        dataProvider's config and is silently ignored — it must be set here,
                        inside data/config, to actually reach the ACL check.
                    -->
                    <item name="aclResource" xsi:type="string">Rgd_Inventory::batch</item>
                </item>
            </argument>
        </argument>
    </dataSource>
    <container name="listing_top">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="template" xsi:type="string">ui/grid/toolbar</item>
                <item name="stickyTmpl" xsi:type="string">ui/grid/sticky/toolbar</item>
            </item>
        </argument>
        <bookmark name="bookmarks">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/controls/bookmarks/bookmarks</item>
                    <item name="storageConfig" xsi:type="array">
                        <item name="namespace" xsi:type="string">rgd_inventory_batch_listing</item>
                    </item>
                </item>
            </argument>
        </bookmark>
        <columnsControls name="columns_controls">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/controls/columns</item>
                    <item name="storageConfig" xsi:type="array">
                        <item name="namespace" xsi:type="string">rgd_inventory_batch_listing</item>
                    </item>
                </item>
            </argument>
        </columnsControls>
        <filterSearch name="fulltext">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/search/search</item>
                    <item name="storageConfig" xsi:type="array">
                        <item name="namespace" xsi:type="string">rgd_inventory_batch_listing</item>
                    </item>
                </item>
            </argument>
        </filterSearch>
        <paging name="listing_paging">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="storageConfig" xsi:type="array">
                        <item name="namespace" xsi:type="string">rgd_inventory_batch_listing</item>
                    </item>
                </item>
            </argument>
        </paging>
    </container>
    <columns name="rgd_inventory_batch_listing_columns">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="childDefaults" xsi:type="array">
                    <item name="fieldAction" xsi:type="array">
                        <item name="provider" xsi:type="string">rgd_inventory_batch_listing.rgd_inventory_batch_listing.columns_actions</item>
                        <item name="target" xsi:type="string">applyAction</item>
                        <item name="params" xsi:type="array">
                            <item name="0" xsi:type="string">${ $.$data.rowIndex }</item>
                            <item name="1" xsi:type="string">${ $.$data.columnIndex }</item>
                        </item>
                    </item>
                </item>
            </item>
        </argument>
        <selectionsColumn name="ids">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="resizeEnabled" xsi:type="boolean">false</item>
                    <item name="resizeDefault" xsi:type="string">40</item>
                    <item name="indexField" xsi:type="string">batch_id</item>
                </item>
            </argument>
        </selectionsColumn>
        <column name="batch_id" sortOrder="10">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">ID</item>
                    <item name="sorting" xsi:type="string">asc</item>
                </item>
            </argument>
        </column>
        <column name="sku" sortOrder="20">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">SKU</item>
                </item>
            </argument>
        </column>
        <column name="batch_number" sortOrder="30">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Batch Number</item>
                </item>
            </argument>
        </column>
        <column name="expiry_date" sortOrder="40">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">dateRange</item>
                    <item name="label" xsi:type="string" translate="true">Expiry Date</item>
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/columns/date</item>
                    <item name="dataType" xsi:type="string">date</item>
                </item>
            </argument>
        </column>
        <column name="received_qty" sortOrder="50">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">textRange</item>
                    <item name="label" xsi:type="string" translate="true">Received Qty</item>
                    <item name="bodyTmpl" xsi:type="string">ui/grid/cells/text</item>
                </item>
            </argument>
        </column>
        <column name="remaining_qty" sortOrder="60">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">textRange</item>
                    <item name="label" xsi:type="string" translate="true">Remaining Qty</item>
                    <item name="bodyTmpl" xsi:type="string">ui/grid/cells/text</item>
                </item>
            </argument>
        </column>
        <column name="source_code" sortOrder="70">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">select</item>
                    <item name="label" xsi:type="string" translate="true">Source</item>
                    <item name="options" xsi:type="array">
                        <item name="0" xsi:type="array">
                            <item name="label" xsi:type="string">Default</item>
                            <item name="value" xsi:type="string">default</item>
                        </item>
                    </item>
                </item>
            </argument>
        </column>
        <column name="is_active" sortOrder="80">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">select</item>
                    <item name="label" xsi:type="string" translate="true">Status</item>
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/columns/select</item>
                    <item name="dataType" xsi:type="string">select</item>
                    <item name="options" xsi:type="array">
                        <item name="1" xsi:type="array">
                            <item name="label" xsi:type="string" translate="true">Active</item>
                            <item name="value" xsi:type="string">1</item>
                        </item>
                        <item name="0" xsi:type="array">
                            <item name="label" xsi:type="string" translate="true">Inactive</item>
                            <item name="value" xsi:type="string">0</item>
                        </item>
                    </item>
                </item>
            </argument>
        </column>
        <column name="created_at" sortOrder="90">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="filter" xsi:type="string">dateRange</item>
                    <item name="label" xsi:type="string" translate="true">Created At</item>
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/columns/date</item>
                    <item name="dataType" xsi:type="string">date</item>
                </item>
            </argument>
        </column>
        <actionsColumn name="actions" class="Rgd\Inventory\Ui\Component\Listing\Column\Actions" sortOrder="100">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="resizeEnabled" xsi:type="boolean">false</item>
                    <item name="resizeDefault" xsi:type="string">107</item>
                    <item name="indexField" xsi:type="string">batch_id</item>
                </item>
            </argument>
        </actionsColumn>
    </columns>
</listing>
