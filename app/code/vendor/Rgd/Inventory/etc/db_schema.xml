<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="rgd_inventory_batch" resource="default" engine="innodb">
        <column xsi:type="int" name="batch_id" unsigned="true" nullable="false" identity="true" comment="Batch ID"/>
        <column xsi:type="varchar" name="sku" nullable="false" length="64" comment="Product SKU"/>
        <column xsi:type="varchar" name="batch_number" nullable="false" length="64" comment="Batch Number"/>
        <column xsi:type="date" name="expiry_date" nullable="true" comment="Expiry Date (NULL = no expiry tracked)"/>
        <column xsi:type="decimal" name="received_qty" nullable="false" precision="12" scale="4" comment="Intake Amount (immutable)"/>
        <!-- Not part of any composite index: it's filtered with a "> 0" range and
             read/summed per-row after the sku/source_code/expiry_date lookup narrows
             the row set, so an index on it wouldn't be seekable here; the admin grid
             filter on this column is low-cardinality/low-volume enough not to warrant
             its own single-column index either. -->
        <column xsi:type="decimal" name="remaining_qty" nullable="false" precision="12" scale="4" unsigned="true" comment="Current Available Quantity"/>
        <column xsi:type="varchar" name="source_code" nullable="false" length="255" default="default" comment="MSI Source Code"/>
        <column xsi:type="smallint" name="is_active" nullable="false" default="1" comment="Active Status (1=active, 0=inactive)"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="batch_id"/>
        </constraint>

        <constraint xsi:type="unique" referenceId="RGD_INVENTORY_BATCH_SKU_BATCH_NUMBER_SOURCE_CODE">
            <column name="sku"/>
            <column name="batch_number"/>
            <column name="source_code"/>
        </constraint>

        <!--
            Covers the FOR UPDATE / FEFO candidate query: sku and source_code are
            always equality predicates, so they lead the index; expiry_date follows
            for the FEFO range/ORDER BY. remaining_qty is intentionally NOT part of
            this index (see comment on the column below) — as a trailing column
            after a range predicate (expiry_date) it could never be used for
            seeking/ordering, only dead weight on every insert/update.
        -->
        <index referenceId="RGD_INVENTORY_BATCH_SKU_SOURCE_CODE_EXPIRY_DATE" indexType="btree">
            <column name="sku"/>
            <column name="source_code"/>
            <column name="expiry_date"/>
        </index>

        <index referenceId="RGD_INVENTORY_BATCH_EXPIRY_DATE" indexType="btree">
            <column name="expiry_date"/>
        </index>

        <index referenceId="RGD_INVENTORY_BATCH_BATCH_NUMBER" indexType="btree">
            <column name="batch_number"/>
        </index>
    </table>

    <table name="rgd_inventory_batch_transaction" resource="default" engine="innodb">
        <column xsi:type="int" name="transaction_id" unsigned="true" nullable="false" identity="true" comment="Transaction ID"/>
        <column xsi:type="int" name="batch_id" unsigned="true" nullable="false" comment="Batch ID"/>
        <column xsi:type="varchar" name="sku" nullable="false" length="64" comment="SKU (denormalized snapshot)"/>
        <column xsi:type="varchar" name="batch_number" nullable="false" length="64" comment="Batch Number (denormalized snapshot)"/>
        <column xsi:type="date" name="expiry_date" nullable="true" comment="Expiry Date (denormalized snapshot)"/>
        <column xsi:type="varchar" name="movement_type" nullable="false" length="32" comment="Movement Type (deduction|return|adjustment|intake)"/>
        <column xsi:type="decimal" name="qty" nullable="false" precision="12" scale="4" comment="Signed Quantity"/>
        <column xsi:type="varchar" name="sales_event_type" nullable="true" length="32" comment="Raw Sales Event Type"/>
        <column xsi:type="int" name="order_id" unsigned="true" nullable="true" comment="Order ID"/>
        <column xsi:type="int" name="order_item_id" unsigned="true" nullable="true" comment="Order Item ID"/>
        <column xsi:type="varchar" name="reference" nullable="true" length="64" comment="Free-text Reference"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="transaction_id"/>
        </constraint>

        <constraint xsi:type="foreign" referenceId="RGD_INV_BATCH_TXN_BATCH_ID_RGD_INV_BATCH_BATCH_ID" table="rgd_inventory_batch_transaction" column="batch_id" referenceTable="rgd_inventory_batch" referenceColumn="batch_id" onDelete="CASCADE"/>

        <index referenceId="RGD_INV_BATCH_TXN_SKU_CREATED_AT" indexType="btree">
            <column name="sku"/>
            <column name="created_at"/>
        </index>

        <index referenceId="RGD_INV_BATCH_TXN_ORDER_ITEM_ID" indexType="btree">
            <column name="order_item_id"/>
        </index>

        <index referenceId="RGD_INV_BATCH_TXN_BATCH_ID" indexType="btree">
            <column name="batch_id"/>
        </index>

        <!-- Admin report filters SKU/Batch Number/Expiry Date/Remaining Quantity
             (per docs/spec-batch-based-inventory-management.md admin UI plan) are
             independent filters that can each be applied on their own, not always
             combined with sku/created_at — so these are separate single-column
             indexes rather than folded into the existing composite, which would
             only help when sku is also present in the filter. -->
        <index referenceId="RGD_INV_BATCH_TXN_BATCH_NUMBER" indexType="btree">
            <column name="batch_number"/>
        </index>

        <index referenceId="RGD_INV_BATCH_TXN_EXPIRY_DATE" indexType="btree">
            <column name="expiry_date"/>
        </index>
    </table>
</schema>
