<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Vendor_ModuleName::main"
                          title="ModuleName"
                          translate="title"
                          sortOrder="100">
                    <resource id="Vendor_ModuleName::manage"
                              title="Manage ModuleName"
                              translate="title"
                              sortOrder="10" />
                    <resource id="Vendor_ModuleName::config"
                              title="ModuleName Configuration"
                              translate="title"
                              sortOrder="20" />
                </resource>
            </resource>
        </resources>
    </acl>
</config>
