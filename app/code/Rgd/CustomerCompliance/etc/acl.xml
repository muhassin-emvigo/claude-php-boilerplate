<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Backend::stores">
                    <resource id="Rgd_CustomerCompliance::compliance" title="Customer Compliance" sortOrder="100">
                        <resource id="Rgd_CustomerCompliance::group_config" title="Group Configuration" sortOrder="10"/>
                        <resource id="Rgd_CustomerCompliance::field" title="Compliance Fields" sortOrder="20"/>
                        <resource id="Rgd_CustomerCompliance::approvals" title="Order Approvals" sortOrder="30">
                            <resource id="Rgd_CustomerCompliance::approve" title="Approve Orders" sortOrder="10"/>
                            <resource id="Rgd_CustomerCompliance::reject" title="Reject Orders" sortOrder="20"/>
                        </resource>
                        <resource id="Rgd_CustomerCompliance::documents" title="Documents" sortOrder="40"/>
                        <resource id="Rgd_CustomerCompliance::audit" title="Audit Log" sortOrder="50"/>
                        <resource id="Rgd_CustomerCompliance::config" title="Configuration" sortOrder="60"/>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
