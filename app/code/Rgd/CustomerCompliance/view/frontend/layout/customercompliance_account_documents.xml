<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="customer_account"/>
    <head>
        <title>My Compliance Documents</title>
    </head>
    <body>
        <referenceBlock name="page.main.title">
            <action method="setPageTitle">
                <argument name="title" xsi:type="string">My Compliance Documents</argument>
            </action>
        </referenceBlock>
        <referenceContainer name="content">
            <block class="Rgd\CustomerCompliance\Block\Account\Documents"
                   name="customercompliance.account.documents"
                   template="Rgd_CustomerCompliance::account/documents.phtml"/>
        </referenceContainer>
    </body>
</page>
