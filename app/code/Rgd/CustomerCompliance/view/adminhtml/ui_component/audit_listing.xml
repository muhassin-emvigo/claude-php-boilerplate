<?xml version="1.0" encoding="UTF-8"?>
<!--
    Read-only Audit Log grid. No actions column - entries are append-only, written exclusively
    via AuditLoggerInterface::log() (see Api\Data\AuditLogEntryInterface's own PHPDoc), so there
    is nothing to edit/delete from the grid.
-->
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">rgd_customercompliance_audit_listing.rgd_customercompliance_audit_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>rgd_customercompliance_audit_columns</spinner>
        <deps>
            <dep>rgd_customercompliance_audit_listing.rgd_customercompliance_audit_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="rgd_customercompliance_audit_listing_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Rgd\CustomerCompliance\Ui\DataProvider\AuditLogDataProvider</argument>
            <argument name="name" xsi:type="string">rgd_customercompliance_audit_listing_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">log_id</argument>
            <argument name="requestFieldName" xsi:type="string">log_id</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="update_url" xsi:type="url" path="mui/index/render"/>
                    <item name="storageConfig" xsi:type="array">
                        <item name="indexField" xsi:type="string">log_id</item>
                    </item>
                </item>
            </argument>
        </argument>
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/grid/provider</item>
            </item>
        </argument>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="rgd_customercompliance_audit_columns">
        <column name="log_id">
            <settings>
                <filter>textRange</filter>
                <sorting>desc</sorting>
                <label translate="true">ID</label>
            </settings>
        </column>
        <column name="entity_type">
            <settings>
                <filter>text</filter>
                <label translate="true">Entity Type</label>
            </settings>
        </column>
        <column name="entity_id">
            <settings>
                <filter>text</filter>
                <label translate="true">Entity ID</label>
            </settings>
        </column>
        <column name="action">
            <settings>
                <filter>text</filter>
                <label translate="true">Action</label>
            </settings>
        </column>
        <column name="actor_type">
            <settings>
                <filter>text</filter>
                <label translate="true">Actor Type</label>
            </settings>
        </column>
        <column name="actor_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Actor ID</label>
            </settings>
        </column>
        <column name="notes">
            <settings>
                <filter>text</filter>
                <sortable>false</sortable>
                <label translate="true">Notes</label>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <sorting>desc</sorting>
                <label translate="true">Created</label>
            </settings>
        </column>
    </columns>
</listing>
