{
    "name": "vendor/magento2-module-boilerplate",
    "description": "Magento 2 PHP Module Boilerplate with Claude Code Integration",
    "type": "project",
    "license": "MIT",
    "version": "1.0.0",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "magento/magento-coding-standard": "*",
        "phpstan/phpstan": "^1.0",
        "phpstan/phpstan-deprecation-rules": "^1.0",
        "phpmd/phpmd": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "captainhook/captainhook": "^5.0",
        "captainhook/hook-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Vendor\\ModuleName\\": "app/code/Vendor/ModuleName/"
        },
        "files": [
            "app/code/Vendor/ModuleName/registration.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Vendor\\ModuleName\\Test\\": "app/code/Vendor/ModuleName/Test/"
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist",
        "test:coverage": "phpunit -c phpunit.xml.dist --coverage-html coverage/",
        "lint": "phpcs --standard=phpcs.xml.dist",
        "lint:fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php",
        "phpstan": "phpstan analyse -c phpstan.neon.dist",
        "phpmd": "phpmd app/code/ text phpmd.xml.dist",
        "check": [
            "@lint",
            "@phpstan",
            "@phpmd",
            "@test"
        ],
        "post-install-cmd": [
            "vendor/bin/phpcs --config-set installed_paths ../../magento/magento-coding-standard/,../../phpcompatibility/php-compatibility/ 2>/dev/null || true"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "captainhook/hook-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
