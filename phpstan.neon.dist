parameters:
    level: 6
    paths:
        - app/code
    excludePaths:
        analyseAndScan:
            - '*/Test/*'
            - 'generated/*'
            - 'vendor/*'
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Magento framework quirks
        - '#Call to an undefined method Magento\\Framework\\App\\RequestInterface::#'
        - '#Call to an undefined method Magento\\Framework\\App\\ResponseInterface::#'

        # Magento auto-generated Factory classes (e.g. FooFactory, FooInterfaceFactory).
        # These are generated by `bin/magento setup:di:compile` into generated/code/,
        # which is excluded from analyseAndScan above, so phpstan cannot resolve them
        # as real classes even though they exist and work correctly at runtime.
        - '#^(Parameter \$[a-zA-Z0-9_]+ of method|Property) [a-zA-Z0-9_\\]+::(\$[a-zA-Z0-9_]+|__construct\(\)) has (invalid type|unknown class) [a-zA-Z0-9_\\]+(Interface)?Factory( as its type)?\.$#'
        - '#^Call to method create\(\) on an unknown class [a-zA-Z0-9_\\]+(Interface)?Factory\.$#'

        # Missing generic array value-type hints (e.g. `array` vs `array<string,mixed>`).
        # Covers both parameter ("... has parameter $x with no value type specified
        # in iterable type array.") and return-type ("... return type has no value
        # type specified in iterable type array.") message shapes. This is level-6
        # pedantry that is pervasive throughout Magento core itself (UI component /
        # data provider constructors, collection getters, etc.) and is not being
        # chased down module-by-module for that reason.
        - '#no value type specified in iterable type array\.$#'

        # Rgd\Inventory: AbstractDb::save()/delete() are typed to accept
        # Magento\Framework\Model\AbstractModel, but our repository/service methods are
        # typed against the API data interfaces (BatchInterface, BatchTransactionInterface)
        # per Magento's own service-contract convention. This is safe here because the
        # only concrete implementations ever passed in (Model\Data\Batch, Model\Data\
        # BatchTransaction) extend AbstractExtensibleModel, which IS an AbstractModel — the
        # same "repository accepts the interface, resource model gets a real AbstractModel
        # at runtime" pattern Magento core itself uses throughout (e.g. ProductRepository).
        # Narrowly scoped to the exact two classes/methods involved, not a blanket AbstractDb ignore.
        -
            message: '#^Parameter \#1 \$object of method Magento\\Framework\\Model\\ResourceModel\\Db\\AbstractDb::(save|delete)\(\) expects Magento\\Framework\\Model\\AbstractModel, Rgd\\Inventory\\Api\\Data\\(Batch|BatchTransaction)Interface given\.$#'
            path: app/code/vendor/Rgd/Inventory/Model/BatchRepository.php
        -
            message: '#^Parameter \#1 \$object of method Magento\\Framework\\Model\\ResourceModel\\Db\\AbstractDb::save\(\) expects Magento\\Framework\\Model\\AbstractModel, Rgd\\Inventory\\Api\\Data\\BatchTransactionInterface given\.$#'
            path: app/code/vendor/Rgd/Inventory/Model/BatchDeductionService.php

        # Rgd\Inventory: Magento\Framework\Data\Collection\AbstractDb::addFieldToFilter()'s own
        # docblock types $condition as array|string|null, but is_active is a tinyint(1) flag
        # column and passing the int 1 directly (equivalent to ['eq' => 1], which IS
        # array|string|null-typed) is the standard, well-established way to filter boolean-ish
        # Magento EAV/flat columns — Magento core collections do the same (e.g.
        # CategoryCollection::addIsActiveFilter() passes a raw int). The docblock is
        # imprecise, not the call site.
        -
            message: '#^Parameter \#2 \$condition of method Magento\\Framework\\Data\\Collection\\AbstractDb::addFieldToFilter\(\) expects array\|string\|null, int given\.$#'
            path: app/code/vendor/Rgd/Inventory/Model/FefoBatchSelector.php
