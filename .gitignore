/package.json.sample
/phpserver/
/pub/
/setup/
/app/.htaccess
/app/autoload.php
/app/bootstrap.php
/app/design/
/app/etc/*
!/app/etc/.gitkeep
/generated/
/var/
vendor.bak.*/

