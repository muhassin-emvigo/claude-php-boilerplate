root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{xml,xsd,xsl}]
indent_size = 4

[*.json]
indent_size = 4

[*.neon]
indent_size = 4
indent_style = tab

[Makefile]
indent_style = tab

[*.{css,less,scss}]
indent_size = 4

[*.js]
indent_size = 4

[*.phtml]
indent_size = 4
